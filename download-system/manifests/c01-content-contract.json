{
  "schema_version": "1.0.0",
  "phase": "C01_PREPRODUCTION",
  "portfolio_id": "C01",
  "canonical_product_id": "IMR-DL-C01",
  "canonical_title": "Italien-Neustart: Budget- und Sicherheitsarbeitsblatt",
  "document_class": "B",
  "portfolio_level": "H1",
  "delivery_model": "FREE_DIRECT",
  "update_class": "U2_MOVING",
  "risk_class": "R2_MODERATE",
  "scope_pages": {"minimum": 8, "maximum": 12},
  "primary_user_task": "Monatsbudget, Startkosten, Rücklage und finanzielle Szenarien nachvollziehbar erfassen und prüfen.",
  "target_group": "Menschen, die Kosten, Startpuffer und Risikomonate für einen Italien-Neustart vorbereiten.",
  "allowed_content": ["Monatsbudget", "Startkosten", "Rücklagen", "verlässliche Einnahmen", "Mindest-Einkommensgrenze als nutzerdefinierte Vergleichsgröße", "Normalmonat", "Stressmonat", "Mindestfall", "Kostenrechner-Abgleich", "offene Kostenpositionen", "nächste Prüfschritte"],
  "forbidden_content": ["Steuerberechnung", "Partita-IVA-Prüfung", "Förderlogik", "Standortbewertung", "individuelle Finanzberatung", "Erfolgsgarantie", "universeller Mindestbetrag", "verbindliche Umzugsfreigabe"],
  "required_components": ["M01", "M02", "M03", "M04", "M05", "M06", "M07", "M08", "M09", "M10", "M11", "M12"],
  "required_inputs": [
    {"id":"monthly_income", "type":"NUTZEREINGABE", "unit":"EUR/month", "period":"month", "reliability":"required"},
    {"id":"essential_monthly_costs", "type":"NUTZEREINGABE", "unit":"EUR/month", "period":"month", "reliability":"required"},
    {"id":"optional_monthly_costs", "type":"NUTZEREINGABE", "unit":"EUR/month", "period":"month", "reliability":"required"},
    {"id":"one_time_start_costs", "type":"NUTZEREINGABE", "unit":"EUR", "period":"one-time", "reliability":"required"},
    {"id":"liquid_reserve", "type":"NUTZEREINGABE", "unit":"EUR", "period":"as-of date", "reliability":"required"},
    {"id":"first_month_costs", "type":"NUTZEREINGABE", "unit":"EUR", "period":"first month", "reliability":"required"},
    {"id":"stress_month_income", "type":"NUTZEREINGABE", "unit":"EUR/month", "period":"scenario", "reliability":"required"},
    {"id":"stress_month_costs", "type":"NUTZEREINGABE", "unit":"EUR/month", "period":"scenario", "reliability":"required"},
    {"id":"minimum_case_income", "type":"NUTZEREINGABE", "unit":"EUR/month", "period":"scenario", "reliability":"required"},
    {"id":"minimum_case_costs", "type":"NUTZEREINGABE", "unit":"EUR/month", "period":"scenario", "reliability":"required"},
    {"id":"user_defined_reserve_target", "type":"NUTZEREINGABE", "unit":"EUR", "period":"target", "reliability":"required"}
  ],
  "calculated_results": ["MONTHLY_INCOME_TOTAL", "ESSENTIAL_MONTHLY_COSTS", "OPTIONAL_MONTHLY_COSTS", "MONTHLY_COSTS_TOTAL", "MONTHLY_BALANCE", "ONE_TIME_START_COSTS", "LIQUID_RESERVE", "RESERVE_COVERAGE_MONTHS", "FIRST_MONTH_COSTS", "STRESS_MONTH_INCOME", "STRESS_MONTH_COSTS", "STRESS_MONTH_BALANCE", "MINIMUM_CASE_INCOME", "MINIMUM_CASE_COSTS", "MINIMUM_CASE_BALANCE", "USER_DEFINED_RESERVE_TARGET", "START_CAPITAL_NEED"],
  "calculation_rules": [
    {"id":"MONTHLY_INCOME_TOTAL", "formula":"sum(monthly reliable income)", "unit":"EUR/month"},
    {"id":"ESSENTIAL_MONTHLY_COSTS", "formula":"sum(necessary monthly costs)", "unit":"EUR/month"},
    {"id":"OPTIONAL_MONTHLY_COSTS", "formula":"sum(non-essential monthly costs)", "unit":"EUR/month"},
    {"id":"MONTHLY_COSTS_TOTAL", "formula":"ESSENTIAL_MONTHLY_COSTS + OPTIONAL_MONTHLY_COSTS", "unit":"EUR/month"},
    {"id":"MONTHLY_BALANCE", "formula":"MONTHLY_INCOME_TOTAL - MONTHLY_COSTS_TOTAL", "unit":"EUR/month"},
    {"id":"ONE_TIME_START_COSTS", "formula":"sum(one-time start costs)", "unit":"EUR"},
    {"id":"LIQUID_RESERVE", "formula":"user input: liquid reserve at the stated as-of date", "unit":"EUR"},
    {"id":"RESERVE_COVERAGE_MONTHS", "formula":"LIQUID_RESERVE / ESSENTIAL_MONTHLY_COSTS", "unit":"months", "zero_denominator":"OFFEN_ZU_PRÜFEN"},
    {"id":"FIRST_MONTH_COSTS", "formula":"user input: costs assigned to the first month", "unit":"EUR"},
    {"id":"STRESS_MONTH_INCOME", "formula":"user input: income assigned to the stress scenario", "unit":"EUR/month"},
    {"id":"STRESS_MONTH_COSTS", "formula":"user input: costs assigned to the stress scenario", "unit":"EUR/month"},
    {"id":"STRESS_MONTH_BALANCE", "formula":"STRESS_MONTH_INCOME - STRESS_MONTH_COSTS", "unit":"EUR/month"},
    {"id":"MINIMUM_CASE_INCOME", "formula":"user input: income assigned to the minimum scenario", "unit":"EUR/month"},
    {"id":"MINIMUM_CASE_COSTS", "formula":"user input: costs assigned to the minimum scenario", "unit":"EUR/month"},
    {"id":"MINIMUM_CASE_BALANCE", "formula":"MINIMUM_CASE_INCOME - MINIMUM_CASE_COSTS", "unit":"EUR/month"},
    {"id":"USER_DEFINED_RESERVE_TARGET", "formula":"user input: reserve target", "unit":"EUR"},
    {"id":"START_CAPITAL_NEED", "formula":"ONE_TIME_START_COSTS + FIRST_MONTH_COSTS + USER_DEFINED_RESERVE_TARGET", "unit":"EUR"}
  ],
  "status_rules": ["Every value has a data type and evidence status.", "A calculated result is not a financial safety or relocation approval."],
  "warning_rules": [
    {"condition":"uncertain income", "risk":"income may not be available as assumed", "meaning":"the scenario basis is uncertain", "next_check":"document reliability and obtain evidence"},
    {"condition":"unknown cost position", "risk":"total costs may be understated", "meaning":"the result is incomplete", "next_check":"identify and classify the missing position"},
    {"condition":"insufficient data basis", "risk":"the calculation has limited reliability", "meaning":"the result is only provisional", "next_check":"complete required inputs and their status"}
  ],
  "blocker_rules": [
    {"condition":"necessary cost position missing", "meaning":"a required calculation input is absent", "consequence":"complete the position before interpreting the result"},
    {"condition":"main income not reliably evidenced", "meaning":"the central income assumption is not sufficiently supported", "consequence":"obtain evidence or mark the scenario unavailable"},
    {"condition":"minimum-case scenario negative", "meaning":"minimum-case income is below minimum-case costs", "consequence":"review assumptions and open conditions; no relocation decision is issued"},
    {"condition":"calculation basis incomplete", "meaning":"a required input, unit or period is missing", "consequence":"complete the data basis before using the result"},
    {"condition":"necessary period missing", "meaning":"a value cannot be compared reliably without its period", "consequence":"record the period or leave the value open"}
  ],
  "source_requirements": ["statement", "value", "unit", "period", "region", "source_type", "source_status", "check_date", "update_class", "evidence_status"],
  "release_dependencies": {"system_acceptance":"BLOCKED", "assistive_tech_gate":"BLOCKED", "pdf_build_allowed":false, "public_pdf_allowed":false, "website_integration_allowed":false, "deployment":false},
  "status": "CONTENT_IN_PROGRESS"
}
