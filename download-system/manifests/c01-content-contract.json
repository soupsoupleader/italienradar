  "data_schema_version":"1.2.0",
  "category_taxonomy_version":"1.0.1",
  "phase":"C01_G2_CANDIDATE",
  "portfolio_id":"C01",
  "canonical_product_id":"IMR-DL-C01",
  "canonical_title":"Italien-Neustart: Budget- und Sicherheitsarbeitsblatt",
  "document_class":"B",
  "portfolio_level":"H1",
  "delivery_model":"FREE_DIRECT",
  "update_class":"U2_MOVING",
  "risk_class":"R2_MODERATE",
  "scope_pages":{"minimum":8,"maximum":12},
  "primary_user_task":"Persönliches Budget, Startkosten, Rücklage und Stressmonate dokumentieren und nachvollziehbar prüfen.",
  "target_group":"Menschen, die Kosten, Startpuffer und Risikomonate für einen Italien-Neustart vorbereiten.",
  "allowed_content":["Monatsbudget","Startkosten","Rücklagen","verlässliche Einnahmen","Normalmonat","Stressmonat","Mindestfall","offene Kostenpositionen","nächste Prüfschritte"],
  "forbidden_content":["Steuerberechnung","Partita-IVA-Prüfung","Förderlogik","Standortbewertung","individuelle Finanzberatung","Erfolgsgarantie","universeller Mindestbetrag","verbindliche Umzugsfreigabe"],
  "required_components":["M01","M02","M03","M04","M05","M06","M07","M08","M09","M10","M11","M12"],
  "required_inputs":[
    {"id":"income_items","type":"NUTZEREINGABE[]","fields":["id","category_id","label","amount","currency","period","data_type","evidence_status","reliability_status"],"allowed_periods":["MONTHLY","ANNUAL","WEEKLY"],"purpose":"Einzelne Einnahmen mit Zuverlässigkeitsstatus"},
    {"id":"essential_cost_items","type":"NUTZEREINGABE[]","fields":["id","category_id","label","amount","currency","period","data_type","evidence_status"],"allowed_periods":["MONTHLY","ANNUAL","WEEKLY"],"purpose":"Einzelne notwendige Monatskosten"},
    {"id":"optional_cost_items","type":"NUTZEREINGABE[]","fields":["id","category_id","label","amount","currency","period","data_type","evidence_status"],"allowed_periods":["MONTHLY","ANNUAL","WEEKLY"],"purpose":"Einzelne optionale Monatskosten"},
    {"id":"start_cost_items","type":"NUTZEREINGABE[]","fields":["id","category_id","label","amount","currency","period","data_type","evidence_status"],"allowed_periods":["ONE_TIME"],"purpose":"Einzelne einmalige Startkosten"},
    {"id":"reserve","type":"NUTZEREINGABE_OBJECT","fields":["amount","currency","as_of_date","evidence_status"],"allowed_periods":["AS_OF_DATE"],"purpose":"Liquiditätsreserve mit Stichtag"},
    {"id":"first_month_costs","type":"NUTZEREINGABE_OBJECT","fields":["amount","currency","scope","overlap_with_start_costs_checked","evidence_status","note"],"allowed_periods":["MONTHLY"],"purpose":"Nur laufende Kosten des ersten Monats, nicht bereits einmalig erfasst"},
    {"id":"normal_scenario","type":"SCENARIO_OBJECT","fields":["income_items","cost_items","assumptions","open_conditions","evidence_status"],"item_period":"SCENARIO","purpose":"Normalfall durch reguläre Monatsergebnisse"},
    {"id":"stress_scenario","type":"SCENARIO_OBJECT","fields":["income_items","cost_items","assumptions","open_conditions","evidence_status"],"item_period":"SCENARIO","purpose":"Ausdrücklich eingegebener Stressfall"},
    {"id":"minimum_scenario","type":"SCENARIO_OBJECT","fields":["income_items","cost_items","assumptions","open_conditions","evidence_status"],"item_period":"SCENARIO","purpose":"Ausdrücklich eingegebener Mindestfall"},
    {"id":"user_defined_reserve_target","type":"NUTZEREINGABE","unit":"EUR","purpose":"Selbst gesetztes Rücklagenziel"}
  ],
  "calculated_results":["REPORTED_MONTHLY_INCOME","UNCERTAIN_MONTHLY_INCOME","MONTHLY_INCOME_TOTAL","ESSENTIAL_MONTHLY_COSTS","OPTIONAL_MONTHLY_COSTS","MONTHLY_COSTS_TOTAL","MONTHLY_BALANCE","ONE_TIME_START_COSTS","LIQUID_RESERVE","RESERVE_COVERAGE_MONTHS","FIRST_MONTH_COSTS","STRESS_MONTH_INCOME","STRESS_MONTH_COSTS","STRESS_MONTH_BALANCE","MINIMUM_CASE_INCOME","MINIMUM_CASE_COSTS","MINIMUM_CASE_BALANCE","USER_DEFINED_RESERVE_TARGET","START_CAPITAL_NEED"],
  "calculation_rules":[
    {"id":"REPORTED_MONTHLY_INCOME","formula":"sum(all income items normalized to monthly values)","unit":"EUR/month"},
    {"id":"UNCERTAIN_MONTHLY_INCOME","formula":"REPORTED_MONTHLY_INCOME - MONTHLY_INCOME_TOTAL","unit":"EUR/month"},
    {"id":"MONTHLY_INCOME_TOTAL","formula":"sum(monthly reliable income)","unit":"EUR/month"},
    {"id":"ESSENTIAL_MONTHLY_COSTS","formula":"sum(necessary monthly costs)","unit":"EUR/month"},
    {"id":"OPTIONAL_MONTHLY_COSTS","formula":"sum(non-essential monthly costs)","unit":"EUR/month"},
    {"id":"MONTHLY_COSTS_TOTAL","formula":"ESSENTIAL_MONTHLY_COSTS + OPTIONAL_MONTHLY_COSTS","unit":"EUR/month"},
    {"id":"MONTHLY_BALANCE","formula":"MONTHLY_INCOME_TOTAL - MONTHLY_COSTS_TOTAL","unit":"EUR/month"},
    {"id":"ONE_TIME_START_COSTS","formula":"sum(one-time start costs)","unit":"EUR"},
    {"id":"LIQUID_RESERVE","formula":"user input at stated as-of date","unit":"EUR"},
    {"id":"RESERVE_COVERAGE_MONTHS","formula":"LIQUID_RESERVE / ESSENTIAL_MONTHLY_COSTS","unit":"months","zero_denominator":"OFFEN"},
    {"id":"FIRST_MONTH_COSTS","formula":"recurring first-month costs not already one-time","unit":"EUR"},
    {"id":"STRESS_MONTH_INCOME","formula":"sum(explicit stress scenario income)","unit":"EUR/month"},
    {"id":"STRESS_MONTH_COSTS","formula":"sum(explicit stress scenario costs)","unit":"EUR/month"},
    {"id":"STRESS_MONTH_BALANCE","formula":"STRESS_MONTH_INCOME - STRESS_MONTH_COSTS","unit":"EUR/month"},
    {"id":"MINIMUM_CASE_INCOME","formula":"sum(explicit minimum scenario income)","unit":"EUR/month"},
    {"id":"MINIMUM_CASE_COSTS","formula":"sum(explicit minimum scenario costs)","unit":"EUR/month"},
    {"id":"MINIMUM_CASE_BALANCE","formula":"MINIMUM_CASE_INCOME - MINIMUM_CASE_COSTS","unit":"EUR/month"},
    {"id":"USER_DEFINED_RESERVE_TARGET","formula":"user input, no automatic threshold","unit":"EUR"},
    {"id":"START_CAPITAL_NEED","formula":"ONE_TIME_START_COSTS + FIRST_MONTH_COSTS + USER_DEFINED_RESERVE_TARGET after overlap check","unit":"EUR"}
  ],
  "status_rules":["Visible result statuses use only the controlled German status values.","not_relevant is separate from evidence_status and requires a reason.","calculation_status is internal and may be INCOMPLETE."],
  "source_requirements":["statement","value","unit","period","region","source_type","publisher","title","source_reference","publication_date","check_date","update_class","evidence_status","allowed_use","affected_categories","affected_sections","verification_status","notes"],
  "release_dependencies":{"system_acceptance":"BLOCKED","assistive_tech_gate":"BLOCKED","pdf_build_allowed":false,"public_pdf_allowed":false,"website_integration_allowed":false,"deployment":false},
  "status":"CONTENT_IN_PROGRESS",
  "result_status_values":["GEKLÄRT","TEILWEISE_GEKLÄRT","OFFEN","OFFIZIELL_ZU_PRÜFEN","FACHLICH_ZU_PRÜFEN","AKTUELL_NICHT_TRAGFÄHIG"],
  "internal_status_values":["COMPLETE","INCOMPLETE"],
  "data_model_reference":"C01_DATA_SCHEMA",
