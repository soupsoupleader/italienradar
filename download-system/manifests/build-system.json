  "postprocessing":{"allowed":"conditional metadata only","rebuild_pdf_forbidden":true,"preserve":["pages","boxes","text","headings","lists","tables","links","StructTreeRoot","MarkInfo","Lang","fonts","security","renders"]},
  "font_source":"download-system/assets/fonts/source-sans-3/",
  "source_manifest_paths":"relative only"
  ,"text_source_canonicalization":"UTF8_NO_BOM_LF",
  "binary_source_hashing":"RAW_BYTES",
  "git_commit_policy":"DYNAMIC_MANIFEST_FIELD",
  "chrome_version_policy":"NORMALIZED_NUMERIC_VERSION"
